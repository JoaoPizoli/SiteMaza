# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

/.claude/
/docs

# dependencies
/node_modules
/front-end/node_modules
/back-end/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/front-end/coverage
/back-end/coverage

# next.js
/.next/
/front-end/.next/
/out/
/front-end/out/

# production
/build
/front-end/build
/back-end/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!**/.env.example

# vercel
.vercel
/front-end/.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
